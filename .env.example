# PostHog EU project API key (phc_...). Analytics is a no-op when unset —
# set locally in .env.local and in the Vercel project env vars.
NEXT_PUBLIC_POSTHOG_KEY=

# Resend (contact/brief form delivery). Unset = the form falls back to a
# prefilled mailto. From-address must belong to a domain verified in Resend
# (recommended: send.koolstudio.pl subdomain, so OVH mailbox DNS stays
# untouched).
RESEND_API_KEY=
BRIEF_FROM_EMAIL="Kool Studio <hello@send.koolstudio.pl>"
BRIEF_TO_EMAIL=hello@koolstudio.pl
