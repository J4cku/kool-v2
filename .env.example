# PostHog EU project API key (phc_...). Analytics is a no-op when unset —
# set locally in .env.local and in the Vercel project env vars.
NEXT_PUBLIC_POSTHOG_KEY=

# Resend (contact/brief form delivery). Unset = the form falls back to a
# prefilled mailto. From-address requires the koolstudio.pl domain verified
# in Resend — its DNS records (DKIM selector + send. return-path subdomain)
# are additive and do not touch the OVH mailbox records.
RESEND_API_KEY=
BRIEF_FROM_EMAIL="Kool Studio <hello@koolstudio.pl>"
BRIEF_TO_EMAIL=hello@koolstudio.pl
